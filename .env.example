# Copy to .env and fill in your values (never commit .env)

FIREBASE_PROJECT_ID=your-firebase-project-id

# Web Firebase (Firebase Console → Project settings → Your apps → Web)
FIREBASE_WEB_APP_ID=1:YOUR_PROJECT_NUMBER:web:YOUR_WEB_APP_HASH
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Google Sign-In (Web OAuth client ID from Firebase Console)
GOOGLE_SIGNIN_CLIENT_ID=YOUR_PROJECT_NUMBER-xxxx.apps.googleusercontent.com

# AI keys
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
# Skip Gemini when credits are depleted (OpenRouter / LocalRules used first)
DISABLE_GEMINI=false
OPEN_AI_API_KEY=sk-proj-your-direct-openai-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost
# Legacy: OPENAI_API_KEY can hold OpenRouter key (sk-or-…) if OPENROUTER_API_KEY is unset
OPENAI_API_KEY=

# Google Maps (also add to android/local.properties as GOOGLE_MAPS_API_KEY for native maps)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Payments (optional — enable packages in pubspec.yaml first)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
CHAPA_API_KEY=CHAPUBK_TEST-your-chapa-key

# Weather (home → Weather quick action)
OPENWEATHER_API_KEY=your-openweather-key

# Legacy backend (optional)
LEGACY_API_URL=http://10.0.2.2:5000
